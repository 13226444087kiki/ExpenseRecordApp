<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/white"
        android:padding="16dp">

        <!-- 顶部标题栏 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingVertical="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="消费记录"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/black" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_settings"
                android:contentDescription="设置"
                app:tint="@color/gray_600" />
        </LinearLayout>

        <!-- 总消费金额卡片 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="24dp"
            android:layout_marginTop="8dp"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="总消费金额"
                android:textSize="16sp"
                android:textColor="@color/gray_600"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tv_total_amount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="¥ 0.00"
                android:textSize="36sp"
                android:textStyle="bold"
                android:textColor="@color/primary" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="本月消费"
                    android:textSize="14sp"
                    android:textColor="@color/gray_600" />

                <TextView
                    android:id="@+id/tv_month_amount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="¥ 0.00"
                    android:textSize="14sp"
                    android:textColor="@color/gray_600"
                    android:layout_marginLeft="8dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- 输入区域 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="20dp"
            android:layout_marginTop="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="添加消费记录"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:layout_marginBottom="16dp" />

            <!-- 类型选择 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="类型 *"
                    android:textSize="14sp"
                    android:textColor="@color/gray_700"
                    android:layout_marginBottom="4dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="@drawable/edittext_background"
                    android:padding="4dp">

                    <Button
                        android:id="@+id/btn_expense"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="支出"
                        android:textSize="16sp"
                        android:paddingVertical="10dp"
                        android:backgroundTint="@color/primary"
                        android:textColor="@color/white" />

                    <Button
                        android:id="@+id/btn_income"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="收入"
                        android:textSize="16sp"
                        android:paddingVertical="10dp"
                        android:layout_marginLeft="8dp"
                        android:backgroundTint="@color/gray_300"
                        android:textColor="@color/gray_700" />
                </LinearLayout>
            </LinearLayout>

            <!-- 金额输入 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="金额 *"
                    android:textSize="14sp"
                    android:textColor="@color/gray_700"
                    android:layout_marginBottom="4dp" />

                <EditText
                    android:id="@+id/et_amount"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="请输入金额"
                    android:inputType="text"
                    android:imeOptions="actionNext"
                    android:maxLines="1"
                    android:padding="12dp"
                    android:background="@drawable/edittext_background"
                    android:textSize="16sp" />
            </LinearLayout>

            <!-- 类别输入 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="类别 *"
                    android:textSize="14sp"
                    android:textColor="@color/gray_700"
                    android:layout_marginBottom="4dp" />

                <EditText
                    android:id="@+id/et_category"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="请输入消费类别（如：餐饮、交通）"
                    android:inputType="text|textCapSentences"
                    android:imeOptions="actionNext"
                    android:maxLines="1"
                    android:padding="12dp"
                    android:background="@drawable/edittext_background"
                    android:textSize="16sp" />
            </LinearLayout>

            <!-- 日期输入 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="日期 *"
                    android:textSize="14sp"
                    android:textColor="@color/gray_700"
                    android:layout_marginBottom="4dp" />

                <EditText
                    android:id="@+id/et_date"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="请输入日期时间（如：2026-04-24 12:30:00）"
                    android:inputType="text"
                    android:imeOptions="actionNext"
                    android:maxLines="1"
                    android:padding="12dp"
                    android:background="@drawable/edittext_background"
                    android:textSize="16sp" />
            </LinearLayout>

            <!-- 备注输入 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="备注"
                    android:textSize="14sp"
                    android:textColor="@color/gray_700"
                    android:layout_marginBottom="4dp" />

                <EditText
                    android:id="@+id/et_note"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="请输入备注信息（可选）"
                    android:inputType="textMultiLine|textCapSentences"
                    android:imeOptions="actionDone"
                    android:maxLines="3"
                    android:padding="12dp"
                    android:background="@drawable/edittext_background"
                    android:textSize="16sp" />
            </LinearLayout>

            <!-- 添加按钮 -->
            <Button
                android:id="@+id/btn_add_expense"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="添加消费"
                android:textSize="16sp"
                android:paddingVertical="14dp"
                android:backgroundTint="@color/primary"
                android:textColor="@color/white"
                android:drawableStart="@drawable/ic_add"
                android:drawablePadding="8dp"
                android:drawableTint="@color/white" />

            <!-- 错误提示 -->
            <TextView
                android:id="@+id/tv_error_message"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="14sp"
                android:textColor="@color/error"
                android:visibility="gone"
                android:layout_marginTop="12dp" />

            <!-- 成功提示 -->
            <TextView
                android:id="@+id/tv_success_message"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="14sp"
                android:textColor="@color/success"
                android:visibility="gone"
                android:layout_marginTop="12dp" />
        </LinearLayout>

        <!-- 功能按钮区域 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="16dp"
            android:background="@drawable/card_background"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="功能测试"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">
                <Button
                    android:id="@+id/btn_send_notification"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="发送通知"
                    android:textSize="14sp"
                    android:paddingVertical="8dp"
                    android:backgroundTint="@color/primary"
                    android:textColor="@color/white" />
                <Button
                    android:id="@+id/btn_send_broadcast"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="发送广播"
                    android:textSize="14sp"
                    android:paddingVertical="8dp"
                    android:layout_marginLeft="8dp"
                    android:backgroundTint="@color/primary"
                    android:textColor="@color/white" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">
                <Button
                    android:id="@+id/btn_start_service"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="启动服务"
                    android:textSize="14sp"
                    android:paddingVertical="8dp"
                    android:backgroundTint="@color/primary"
                    android:textColor="@color/white" />
                <Button
                    android:id="@+id/btn_stop_service"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="停止服务"
                    android:textSize="14sp"
                    android:paddingVertical="8dp"
                    android:layout_marginLeft="8dp"
                    android:backgroundTint="@color/primary"
                    android:textColor="@color/white" />
            </LinearLayout>

            <Button
                android:id="@+id/btn_test_provider"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="测试ContentProvider"
                android:textSize="14sp"
                android:paddingVertical="8dp"
                android:backgroundTint="@color/primary"
                android:textColor="@color/white" />

            <!-- 状态显示区域 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="12dp">
                <TextView
                    android:id="@+id/tv_broadcast_status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="广播状态：未注册"
                    android:textSize="12sp"
                    android:textColor="@color/gray_600"
                    android:layout_marginBottom="4dp" />
                <TextView
                    android:id="@+id/tv_service_status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="服务状态：未启动"
                    android:textSize="12sp"
                    android:textColor="@color/gray_600"
                    android:layout_marginBottom="4dp" />
                <TextView
                    android:id="@+id/tv_provider_status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="ContentProvider状态：未测试"
                    android:textSize="12sp"
                    android:textColor="@color/gray_600" />
            </LinearLayout>
        </LinearLayout>

        <!-- 在输入区域和列表区域之间添加一个按钮 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="16dp"
            android:gravity="center">

            <Button
                android:id="@+id/btn_view_records"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="查看详细记录"
                android:textSize="16sp"
                android:paddingHorizontal="32dp"
                android:paddingVertical="12dp"
                android:backgroundTint="@color/gray_300"
                android:textColor="@color/gray_700"
                android:drawableStart="@drawable/ic_list"
                android:drawablePadding="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="点击查看完整的记账记录列表"
                android:textSize="12sp"
                android:textColor="@color/gray_500"
                android:layout_marginTop="8dp" />
        </LinearLayout>

        <!-- 消费记录列表区域 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/gray_50"
            android:padding="16dp"
            android:layout_marginTop="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="费用记录"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:layout_marginBottom="16dp" />

            <!-- 列表容器 - 改为固定高度 -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_expense_list"
                android:layout_width="match_parent"
                android:layout_height="300dp"
                android:nestedScrollingEnabled="true" />

            <!-- 空状态提示 -->
            <LinearLayout
                android:id="@+id/ll_empty_state"
                android:layout_width="match_parent"
                android:layout_height="300dp"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="32dp"
                android:visibility="visible">

                <ImageView
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:src="@drawable/ic_empty_list"
                    android:contentDescription="空列表"
                    app:tint="@color/gray_400" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="暂无消费记录"
                    android:textSize="16sp"
                    android:textColor="@color/gray_500"
                    android:layout_marginTop="16dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="添加第一条记录开始使用"
                    android:textSize="14sp"
                    android:textColor="@color/gray_400"
                    android:layout_marginTop="8dp" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</ScrollView>